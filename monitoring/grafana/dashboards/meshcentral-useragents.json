{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Unique User Agents",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Number of distinct User-Agent strings seen within the selected timeframe.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(sum by (request_User_Agent) (count_over_time({job=\"traefik-access\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "Unique User Agents",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "title": "Unique Source IPs",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Number of distinct client IP addresses seen within the selected timeframe.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(sum by (ClientHost) (count_over_time({job=\"traefik-access\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "Unique IPs",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Total number of requests within the selected timeframe.",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"traefik-access\"} | json | __error__=\"\" [$__range]))",
          "legendFormat": "Requests",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "title": "User Agent \u2014 Source IP Breakdown",
      "type": "table",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Each distinct (User-Agent, Source IP) pair with its total request count within the selected timeframe.",
      "options": {
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        },
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Requests",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "request_User_Agent"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "User Agent"
              },
              {
                "id": "custom.width",
                "value": 520
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ClientHost"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Source IP"
              },
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Requests"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlPu"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (request_User_Agent, ClientHost) (count_over_time({job=\"traefik-access\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "",
          "refId": "A",
          "queryType": "instant",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "tsNs": true
            },
            "indexByName": {
              "request_User_Agent": 0,
              "ClientHost": 1,
              "Value": 2
            },
            "renameByName": {}
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Top 20 User Agents by Request Count",
      "type": "bargauge",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Top 20 User-Agent strings ranked by total request count within the selected timeframe.",
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(20, sum by (request_User_Agent) (count_over_time({job=\"traefik-access\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "{{request_User_Agent}}",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top 20 Source IPs by Request Count",
      "type": "bargauge",
      "gridPos": {
        "h": 12,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Top 20 client IP addresses ranked by total request count within the selected timeframe.",
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(20, sum by (ClientHost) (count_over_time({job=\"traefik-access\"} | json | __error__=\"\" [$__range])))",
          "legendFormat": "{{ClientHost}}",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "traefik",
    "meshcentral",
    "useragents"
  ],
  "templating": {
    "list": [
      {
        "hide": 2,
        "name": "DS_LOKI",
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
